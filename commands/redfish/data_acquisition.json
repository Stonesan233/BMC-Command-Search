    "url": "/redfish/v1/DataAcquisitionService",
    "command": "curl -k -u admin:password -X PATCH 'https://<bmc_ip>/redfish/v1/DataAcquisitionService' -H 'Content-Type: application/json' -d '{  \"Type\": \"text\",  \"Content\": \"content\" }'",
    "description": "打开/关闭数据采集服务。本资源受许可证控制，需要通过许可证授权后才能使用。",
    "request_body": "{\n  \"Type\": \"text\",\n  \"Content\": \"content\"\n}"
  },
