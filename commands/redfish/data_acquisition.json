    "section": "3.11.1",
    "title": "查询数据采集服务资源",
    "method": "GET",
    "url": "/redfish/v1/DataAcquisitionService",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/DataAcquisitionService'",
    "description": "查询数据采集服务资源。本资源受许可证控制，需要通过许可证授权后才能使用。",
    "request_body": "{\n  \"Type\": \"text\",\n  \"Content\": \"content\"\n}"
  },
  {
