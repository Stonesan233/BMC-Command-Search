[
  {
    "section": "3.14.1",
    "title": "查询编排任务服务信息",
    "method": "GET",
    "url": "/redfish/v1/JobService",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/JobService'",
    "description": "查询服务器当前编排任务服务信息。  说明 \t\t\tiBMC300 5.8.0.1及以上版本支持",
    "request_body": "{\n  \"ResetType\": \"ForceRestart\"\n}"
  },
  {
    "section": "3.14.2",
    "title": "修改编排任务服务信息",
    "method": "PATCH",
    "url": "/redfish/v1/JobService",
    "command": "curl -k -u admin:password -X PATCH 'https://<bmc_ip>/redfish/v1/JobService' -H 'Content-Type: application/json' -d '{  \"ResetType\": \"ForceRestart\" }'",
    "description": "修改服务器当前编排任务的服务信息。  说明 \tiBMC300 5.8.0.1及以上版本支持",
    "request_body": "{\n  \"ResetType\": \"ForceRestart\"\n}"
  },
  {
    "section": "3.14.4",
    "title": "创建编排任务",
    "method": "POST",
    "url": "/redfish/v1/JobService/Jobs",
    "command": "curl -k -u admin:password -X POST 'https://<bmc_ip>/redfish/v1/JobService/Jobs' -H 'Content-Type: application/json' -d '{  \"ResetType\": \"ForceRestart\" }'",
    "description": "创建编排任务。  说明  iBMC300 5.8.0.1及以上版本支持",
    "request_body": "{\n  \"ResetType\": \"ForceRestart\"\n}"
  },
  {
    "section": "3.14.5",
    "title": "查询指定编排任务信息",
    "method": "GET",
    "url": "/redfish/v1/JobService/Jobs/job_id",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/JobService/Jobs/job_id'",
    "description": "查询指定编排任务信息",
    "request_body": "{\n  \"ResetType\": \"ForceRestart\"\n}"
  },
  {
    "section": "3.14.6",
    "title": "修改指定编排任务信息",
    "method": "PATCH",
    "url": "/redfish/v1/JobService/Jobs/job_id",
    "command": "curl -k -u admin:password -X PATCH 'https://<bmc_ip>/redfish/v1/JobService/Jobs/job_id' -H 'Content-Type: application/json' -d '{}'",
    "description": "修改指定编排任务信息。  说明  iBMC300 5.8.0.1及以上版本支持",
    "request_body": ""
  }
]