  },
  {
    "section": "3.5.7",
    "title": "创建Web 会话",
    "method": "POST",
    "url": "/redfish/v1/SessionService/Sessions",
    "command": "curl -k -u admin:password -X POST 'https://<bmc_ip>/redfish/v1/SessionService/Sessions' -H 'Content-Type: application/json' -d '{}'",
    "description": "创建新会话，Web使用此会话可通过Redfish接口获取和设置信息。",
    "request_body": ""
  },
  {
    "section": "3.5.8",
    "title": "Web 执行操作",
    "method": "GET",
    "url": "/redfish/v1/SessionService/Sessions",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/SessionService/Sessions'",
    "description": "使用Web会话通过Redfish接口执行查询、设置操作。所有请求中不再携带X-Auth-Token，所有操作响应头中不再返回“ETag”参数，PATCH操作请求头不再携带“If-Match”。",
    "request_body": "{\n  \"TransferProtocol\": \"HTTPS\",\n  \"Path\": \"/tmp/web/aaa.tar.gz\"\n}"
