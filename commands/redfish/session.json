[
  {
    "section": "3.5.1",
    "title": "查询会话服务信息",
    "method": "GET",
    "url": "/redfish/v1/SessionService",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/SessionService'",
    "description": "查询服务器当前会话服务的信息。",
    "request_body": "{\n  \"Language\": \"fr\"\n}"
  },
  {
    "section": "3.5.2",
    "title": "修改会话服务信息",
    "method": "PATCH",
    "url": "/redfish/v1/SessionService",
    "command": "curl -k -u admin:password -X PATCH 'https://<bmc_ip>/redfish/v1/SessionService' -H 'Content-Type: application/json' -d '{  \"Language\": \"fr\" }'",
    "description": "修改服务器当前会话服务的超时时间。",
    "request_body": "{\n  \"Language\": \"fr\"\n}"
  },
  {
    "section": "3.5.3",
    "title": "创建会话",
    "method": "POST",
    "url": "/redfish/v1/SessionService/Sessions",
    "command": "curl -k -u admin:password -X POST 'https://<bmc_ip>/redfish/v1/SessionService/Sessions' -H 'Content-Type: application/json' -d '{  \"Language\": \"fr\" }'",
    "description": "创建新会话。",
    "request_body": "{\n  \"Language\": \"fr\"\n}"
  },
  {
    "section": "3.5.4",
    "title": "查询会话集合资源信息",
    "method": "GET",
    "url": "/redfish/v1/SessionService/Sessions",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/SessionService/Sessions'",
    "description": "查询服务器当前会话集合资源信息。",
    "request_body": "{\n  \"Language\": \"fr\"\n}"
  },
  {
    "section": "3.5.5",
    "title": "查询指定会话资源信息",
    "method": "GET",
    "url": "/redfish/v1/SessionService/Sessions/session_id",
    "command": "curl -k -u admin:password -X GET 'https://<bmc_ip>/redfish/v1/SessionService/Sessions/session_id'",
    "description": "查询服务器指定会话资源信息。",
    "request_body": ""
  },
  {
