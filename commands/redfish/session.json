    "title": "删除指定会话",
    "method": "DELETE",
    "url": "/redfish/v1/SessionService/Sessions/session_id",
    "command": "curl -k -u admin:password -X DELETE 'https://<bmc_ip>/redfish/v1/SessionService/Sessions/session_id'",
    "description": "删除指定会话。",
